# Optional: API base URL (including /api). Use if the API runs on a different host/port.
# Default in dev: http://localhost:3001/api
# Example if your API is on port 3002:
# VITE_API_BASE=http://localhost:3002/api
#
# Production (Azure, etc.): do NOT set VITE_API_BASE to localhost — it gets baked into the
# bundle and users' browsers will try to call YOUR computer. Omit VITE_API_BASE when the UI
# and API share the same host (relative /api). For a separate API host use:
# VITE_API_BASE=https://your-app.azurewebsites.net/api
